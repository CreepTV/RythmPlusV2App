{
  "name": "rhythm-plus-v2",
  "version": "1.1.6",
  "description": "Rhythm Plus V2 Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "taskkill /F /IM \"Rhythm Plus V2.exe\" /T 2>nul & taskkill /F /IM \"electron.exe\" /T 2>nul & timeout /T 2 /NOBREAK >nul & del /f /q \"dist\\win-unpacked\\resources\\app.asar\" 2>nul & rd /s /q dist\\win-unpacked 2>nul & exit 0",
    "build": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.rhythmplus.v2",
    "productName": "Rhythm Plus V2",
    "icon": "data/rythmplus-icon.png",
    "publish": [
      {
        "provider": "github",
        "owner": "CreepTV",
        "repo": "RythmPlusV2App"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "data/rythmplus-icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "data/rythmplus-icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "data/rythmplus-icon.png"
    }
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.3.9"
  }
}
